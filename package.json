{
  "name": "sicredi-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo Sicredi (API Laravel + Front Next.js)",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:api": "cd apps/api && php artisan serve",
    "dev:front": "cd apps/front && npm run dev",
    "dev": "concurrently -n api,front -c blue,yellow \"npm:dev:api\" \"npm:dev:front\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
